-- ===== FUNGSI UNTUK MEMBUAT DAFTAR ITEM + SWITCH BUY ALL =====
local function buildItemList(container, itemList, listName)
    -- Hapus isi container lama (kalau ada)
    for _, child in ipairs(container:GetChildren()) do
        child:Destroy()
    end

    -- Switch Buy All (Auto-Loop)
    local buyAllSwitch = Instance.new("TextButton")
    buyAllSwitch.Name = "BuyAllSwitch_" .. listName
    buyAllSwitch.Size = UDim2.new(0.15, 0, 0.08, 0)
    buyAllSwitch.Position = UDim2.new(0.8, 0, 0.01, 0)
    buyAllSwitch.Text = "OFF"
    buyAllSwitch.TextColor3 = Color3.new(1,1,1)
    buyAllSwitch.TextSize = 14
    buyAllSwitch.BackgroundColor3 = Color3.new(0.5,0.5,0.5)
    buyAllSwitch.BorderSizePixel = 0
    buyAllSwitch.Parent = container

    local switchOn = false
    local loopConnection = nil

    local function stopAutoBuy()
        if loopConnection then
            loopConnection:Disconnect()
            loopConnection = nil
        end
    end

    local function startAutoBuy()
        stopAutoBuy()
        loopConnection = game:GetService("RunService").Heartbeat:Connect(function()
            for _, item in ipairs(itemList) do
                pcall(item.buyRemote)
            end
            task.wait(5)
        end)
    end

    local function updateSwitch()
        if switchOn then
            buyAllSwitch.Text = "ON"
            buyAllSwitch.BackgroundColor3 = Color3.new(0.2,0.8,0.2)
            startAutoBuy()
        else
            buyAllSwitch.Text = "OFF"
            buyAllSwitch.BackgroundColor3 = Color3.new(0.5,0.5,0.5)
            stopAutoBuy()
        end
    end

    buyAllSwitch.MouseButton1Click:Connect(function()
        switchOn = not switchOn
        updateSwitch()
    end)
    updateSwitch()

    -- ScrollingFrame untuk daftar item
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name = "Scroll_" .. listName
    scroll.Size = UDim2.new(1, 0, 0.9, 0)
    scroll.Position = UDim2.new(0, 0, 0.1, 0)
    scroll.BackgroundColor3 = Color3.new(0.1,0.1,0.1)
    scroll.BackgroundTransparency = 0.5
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 8
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.Parent = container

    -- Fungsi untuk membuat item
    local function createItem(parent, itemName, index)
        local item = Instance.new("Frame")
        item.Size = UDim2.new(1, 0, 0, 40)
        item.Position = UDim2.new(0, 0, 0, (index-1)*45)
        item.BackgroundColor3 = Color3.new(0.15,0.15,0.15)
        item.BackgroundTransparency = 0.5
        item.BorderSizePixel = 0
        item.Parent = parent

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(0.6, 0, 1, 0)
        nameLabel.Position = UDim2.new(0, 5, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = itemName
        nameLabel.TextColor3 = Color3.new(1,1,1)
        nameLabel.TextSize = 18
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = item

        local buyBtn = Instance.new("TextButton")
        buyBtn.Size = UDim2.new(0.15, 0, 0.7, 0)
        buyBtn.Position = UDim2.new(0.8, 0, 0.15, 0)
        buyBtn.Text = "Beli"
        buyBtn.TextColor3 = Color3.new(1,1,1)
        buyBtn.BackgroundColor3 = Color3.new(0.2,0.5,0.2)
        buyBtn.BackgroundTransparency = 0.3
        buyBtn.BorderSizePixel = 0
        buyBtn.Parent = item

        buyBtn.MouseButton1Click:Connect(function()
            for _, itemData in ipairs(itemList) do
                if itemData.name == itemName then
                    pcall(itemData.buyRemote)
                    break
                end
            end
        end)
    end

    -- Isi scroll
    for i, item in ipairs(itemList) do
        createItem(scroll, item.name, i)
    end
    scroll.CanvasSize = UDim2.new(0, 0, 0, #itemList * 45 + 10)
end

