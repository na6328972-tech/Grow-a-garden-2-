buyAllSwitch.BorderSizePixel = 0
buyAllSwitch.Parent = seedContainer

local switchOn = false
local loopConnection = nil

local function stopAutoBuy()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
end

local function startAutoBuy()
    stopAutoBuy()
    loopConnection = game:GetService("RunService").Heartbeat:Connect(function()
        for _, seed in ipairs(seedList) do
            pcall(seed.buyRemote)
        end
        task.wait(0.5)
    end)
end

local function updateSwitch()
    if switchOn then
        buyAllSwitch.Text = "ON"
        buyAllSwitch.BackgroundColor3 = Color3.new(0.2,0.8,0.2)
        startAutoBuy()
    else
        buyAllSwitch.Text = "OFF"
        buyAllSwitch.BackgroundColor3 = Color3.new(0.5,0.5,0.5)
        stopAutoBuy()
    end
end

buyAllSwitch.MouseButton1Click:Connect(function()
    switchOn = not switchOn
    updateSwitch()
end)
updateSwitch()

