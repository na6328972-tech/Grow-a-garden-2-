-- Fungsi untuk membuat item seed
local function createSeedItem(parent, seedName, index)
    local item = Instance.new("Frame")
    item.Size = UDim2.new(1, 0, 0, 40)
    item.Position = UDim2.new(0, 0, 0, (index-1)*45)
    item.BackgroundColor3 = Color3.new(0.15,0.15,0.15)
    item.BackgroundTransparency = 0.5
    item.BorderSizePixel = 0
    item.Parent = parent

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0.6, 0, 1, 0)
    nameLabel.Position = UDim2.new(0, 5, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = seedName
    nameLabel.TextColor3 = Color3.new(1,1,1)
    nameLabel.TextSize = 18
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = item

    local buyBtn = Instance.new("TextButton")
    buyBtn.Size = UDim2.new(0.15, 0, 0.7, 0)
    buyBtn.Position = UDim2.new(0.8, 0, 0.15, 0)
    buyBtn.Text = "Beli"
    buyBtn.TextColor3 = Color3.new(1,1,1)
    buyBtn.BackgroundColor3 = Color3.new(0.2,0.5,0.2)
    buyBtn.BackgroundTransparency = 0.3
    buyBtn.BorderSizePixel = 0
    buyBtn.Parent = item

    buyBtn.MouseButton1Click:Connect(function()
        for _, seed in ipairs(seedList) do
            if seed.name == seedName then
                pcall(seed.buyRemote)
                break
            end
        end
    end)
end

-- Isi seedScroll
for i, seed in ipairs(seedList) do
